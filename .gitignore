# ── secrets — NEVER commit ───────────────────────────────────────────────
.env
.env.*
env.txt
*.pem
*.key
*.crt
*.p12

# ── SAP NWRFC SDK (licensed, NOT redistributable — download separately) ───
nwrfcsdk/
mcp_remote/nwrfcsdk/

# ── runtime data / regenerable (not source) ──────────────────────────────
logs/
vector_store/
tts_cache/
kg_instances.json
genesis_ledger.json
adk_sessions.db
*.db
*.db-journal
.adk/

