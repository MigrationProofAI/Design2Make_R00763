expand_*.json
code_book.json
dev_rfc.log

# ── python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# ── node / vite (the served bundle in static_v2/ IS committed) ────────────
frontend/node_modules/
frontend/dist/
node_modules/

