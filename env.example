# Design2Make -- environment TEMPLATE (placeholders only; no real keys live here).
# Copy to `.env`, then REPLACE every value below with YOUR OWN keys/credentials.
# The filled-in `.env` is gitignored and must NEVER be committed, shared, or pushed --
# keep it on your own machine only.
# IMPORTANT: keep this file (and your .env) saved as UTF-8 — not ANSI/Windows-1252.

# ---- OpenAI (LLMs + embeddings + TTS) -------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini                 # default cheap model (search, explain, tour narration)
OPENAI_MODEL_WRITE=gpt-4o-mini           # genesis/writers (vision-capable). Set gpt-4o for stronger.
OPENAI_MODEL_CONDUCTOR=gpt-4o            # the ONLY non-cheap agent -- boardroom conductor
TOUR_VOICE=nova                          # tts-1 voice for the tour/demo (alloy, shimmer, onyx, ...)
TOUR_TTS_TIMEOUT=9                        # per-attempt TTS timeout (s)

# ---- Semantic dedup (vector.py / genesis) ---------------------------------
DEDUP_THRESHOLD=0.92                      # cosine >= this => auto-reuse the existing material
DEDUP_FROM=                              # optional SAP material-number range to scope dedup within
DEDUP_TO=                                # (empty = search the whole index)

# ---- Local SAP OData (sap.py / make.py: material, PIR, cost, BOM, routing) -
SAP_HOST=vhcals4hci.example.com
SAP_HTTPS_PORT=44301
SAP_CLIENT=100
SAP_USER=YOURUSER
SAP_PASS=changeme
SAP_PLANT=1710
SAP_LANG=EN
SAP_SPRAS=E
SAP_CURRENCY=USD
SAP_PURCH_ORG=1710
SAP_PURCH_GROUP=001

# ---- The ADK app only needs the remote MCP URLs (it holds NO RFC creds) ----
# Planning (MRP + demand) and Production-version (MKAL) run as separate RFC processes (mcp_remote/).
PLANNING_MCP_URL=http://127.0.0.1:8001/sse
PRODVER_MCP_URL=http://127.0.0.1:8002/sse

# ===========================================================================
# mcp_remote/  -- the RFC MCP servers (sap_planning_mcp.py :8001, sap_prodvers_mcp.py :8002)
# Put THESE in mcp_remote/.env (NOT the app's). They need the SAP NWRFC SDK installed
# (download into mcp_remote/nwrfcsdk/ -- it is NOT in this repo; see README).
# ===========================================================================
MCP_HOST=127.0.0.1
# MCP_PORT -- leave UNSET here. run.sh / run.bat set it per server (planning 8001, prod-version 8002);
# if you set one value here, BOTH servers would grab the same port.
MCP_TRANSPORT=sse
SAP_RFC_HOST=vhcals4hci.example.com      # SAP application server host (ashost)
SAP_RFC_SYSNR=01                         # system number
SAP_RFC_CLIENT=100
SAP_RFC_USER=YOURUSER
SAP_RFC_PASSWORD=changeme
SAP_RFC_LANG=EN
SAP_RFC_WERKS=1710                       # default plant for MRP/demand
SAP_RFC_MATNR=                           # optional default material for smoke tests

# ---- Misc -----------------------------------------------------------------
SERPER_API_KEY=                          # optional web-search tool (serper.py)
SESSION_DB_URL=sqlite:///./adk_sessions.db
SAP_LIVE_TESTS=0                          # set 1 to run live SAP integration tests
